{
    // Версия формата launch.json — служебное поле.
    "version": "0.2.0",

    // Массив конфигураций запуска. У нас будет одна — "запустить lab.exe под gdb".
    "configurations": [
        {
            // Имя конфигурации. Будет видно в выпадающем списке в панели Debug
            // и в зелёной кнопке "Run and Debug".
            "name": "Debug lab.exe (gdb)",

            // Тип отладчика. Расширение C/C++ от Microsoft регистрирует тип "cppdbg".
            "type": "cppdbg",

            // "launch" — запустить программу заново. Альтернатива "attach" — прицепиться
            // к уже запущенной программе, нам не нужно.
            "request": "launch",

            // Какой .exe запускать. ${workspaceFolder} — корень проекта.
            "program": "${workspaceFolder}/build/lab.exe",

            // Аргументы командной строки для нашей программы (если бы они были).
            // У нас программа интерактивная — аргументы не нужны, оставляем пустым.
            "args": [],

            // false — отладчик НЕ останавливается на первой строке main автоматически.
            // Если true — программа замрёт на самой первой инструкции, ждать F5.
            "stopAtEntry": false,

            // Рабочая папка для программы во время запуска.
            // Важно: пути типа "data/students.csv" будут считаться относительно неё.
            "cwd": "${workspaceFolder}",

            // Переменные окружения для запускаемой программы. Пока пусто.
            "environment": [],

            // "externalConsole": true — открыть программу в ОТДЕЛЬНОМ окне cmd.
            //   Это важно для интерактивных программ на Windows: встроенная "Debug Console"
            //   VS Code плохо обрабатывает scanf. В отдельной консоли всё работает корректно.
            "externalConsole": true,

            // Какой именно отладчик использовать. На Windows + MinGW — это gdb.
            "MIMode": "gdb",

            // Путь к gdb.exe. Мы установили MinGW в C:\mingw64, gdb лежит рядом с gcc.
            "miDebuggerPath": "C:/mingw64/bin/gdb.exe",

            // Что сделать ПЕРЕД запуском отладки.
            // "build lab" — имя задачи из tasks.json. То есть VS Code сначала пересоберёт
            // программу (вызовет gcc), и только потом запустит gdb. Это удобно: внёс правку,
            // нажал F5 — VS Code сам собирает и сразу отлаживает.
            "preLaunchTask": "build lab",

            // Дополнительные команды для gdb при старте. Эта говорит "выводить красиво"
            // (массивы, структуры — в читаемом виде, а не в одну строку).
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
