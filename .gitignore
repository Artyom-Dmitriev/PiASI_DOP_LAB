# Собранные исполняемые файлы и объектники — их каждый собирает у себя сам.
build/
*.exe
*.o
*.obj

# Файлы данных, которые программа создаёт при работе.
# Структура папки сохранится за счёт .gitkeep (см. ниже).
data/*.csv
data/*.bin
data/*.txt

# Файлы отладочной информации gdb.
*.pdb

# Системные файлы Windows / macOS.
Thumbs.db
desktop.ini
.DS_Store

# Извлечённый из docx markdown — служебный файл, не часть проекта.
lab_content.md
